# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.agents/
_bmad/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Local tooling — Claude Code session/worktree state, not for sharing.
.claude/

# Playwright run output — regenerated on every test run.
playwright-report/
test-results/

# Local one-off diff/patch scratch files generated during code review.
.review-diff-tmp.diff
*.patch

# Local debug/inspection scripts — created ad-hoc during incident triage.
# Kept locally so they're available next time without re-typing, but not
# shared (they hard-code dev-db URLs or contain throwaway diagnostics).
/scripts/count-user-data.ts
/scripts/list-tables.ts
/scripts/peek-verify-email.ts
/scripts/reset-users.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# Mock-tutor seed default assets (uploaded once to R2 via scripts/upload-mock-defaults.ts)
/mock-assets/
