# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/teachme
DATABASE_URL_UNPOOLED=postgres://user:password@localhost:5432/teachme
SEED_ADMIN_EMAIL=admin@teachme.local

# Auth
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Provider selection, MVP 1 defaults to stubs.
PAYMENTS_PROVIDER=stub
INVOICE_PROVIDER=stub
GOVIL_PROVIDER=stub
LESSON_ROOM_PROVIDER=stub
EMAIL_PROVIDER=stub

# Observability, filled in Story 1.8.
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# CI / security
SOCKET_SECURITY_API_KEY=

# Dev-only convenience flags. NEVER set in production — every helper in
# src/lib/auth/dev-flags.ts hard-refuses to activate when NODE_ENV=production.
#
# DEV_SKIP_EMAIL_VERIFICATION=1 — signup creates the user with email_verified=now()
# and redirects to /signin?verified=1 instead of the verify-email-sent screen.
# Useful when iterating against a stub email outbox; skip when testing the real
# verification loop. Effect is permanent for the user it creates — i.e., once a
# user signs up under this flag, their email is considered verified forever
# even after the flag is turned off.
DEV_SKIP_EMAIL_VERIFICATION=
